# ============================================================
# CryptX Server — Environment Variables
# Copy this file to .env and fill in your real values
# ============================================================

# Server
PORT=5000
NODE_ENV=development

# JWT Secret (use a long random string, e.g. openssl rand -hex 64)
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=7d

# Firebase Admin SDK
# Download your service account key from:
# Firebase Console → Project Settings → Service Accounts → Generate New Private Key
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----\n"

# Email (for OTP & password reset)
# Recommended: Create a Gmail App Password at myaccount.google.com/apppasswords
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your.email@gmail.com
EMAIL_PASS=your_app_password_here
EMAIL_FROM="CryptX Security <your.email@gmail.com>"

# Client URL (for CORS)
CLIENT_URL=http://localhost:3000

# OTP Expiry in minutes
OTP_EXPIRY_MINUTES=10
